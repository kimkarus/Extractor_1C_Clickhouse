Процедура ВыгрузитьДанныеClickHouse_ОперативныйОтчетЛогисты_НаСервере(Параметры)
	
	СтандартнаяОбработка = Ложь;
	
	СхемаКомпоновкиДанных = ПолучитьМакет("Запрос"+Параметры.ИмяТаблицы);
	Запрос = Новый Запрос;
	Запрос.Текст = СхемаКомпоновкиДанных.НаборыДанных[0].Запрос;
	//
	ПараметрыМакета = СхемаКомпоновкиДанных.Параметры;
	//
	Если Не ЕстьТаблицаВClickHouse(Параметры.ИмяТаблицы, Параметры) Тогда
		ТекстЗапроса = ТекстЗапросаСозданиеТаблицыБросаниеВагоновТип(Параметры);
		ТаблицаСоздана = ВыполнитьЗапросPOST_ClickHouse(ТекстЗапроса, Параметры);
	КонецЕсли;
	//
	Для каждого СтрокаПараметра из ПараметрыМакета Цикл
		Если СтрНайти(СтрокаПараметра.Имя, "Период") > 0 Тогда
			Запрос.УстановитьПараметр(СтрокаПараметра.Имя, Параметры.ДатаНачала);
		Иначе
			Запрос.УстановитьПараметр(СтрокаПараметра.Имя, СтрокаПараметра.Значение);
		КонецЕсли;
	КонецЦикла;
	Запрос.УстановитьПараметр("ВключитьОтборТолькоБросание", Истина);
	//
	Если НачалоДня(Параметры.ДатаОкончания) <> НачалоДня(Параметры.ДатаНачала) Тогда
		КоличествоДней = РозностьВДнях(Параметры.ДатаОкончания, Параметры.ДатаНачала);
		НоваяДатаОтчета = НачалоДня(Параметры.ДатаНачала);
		Для Счетчик = 1 По КоличествоДней + 1 Цикл
			//
			Для каждого СтрокаПараметра из ПараметрыМакета Цикл
				Если СтрНайти(ВРег(СтрокаПараметра.Имя), ВРег("Период")) > 0 Тогда
					Запрос.УстановитьПараметр(СтрокаПараметра.Имя, НоваяДатаОтчета);
				КонецЕсли;
			КонецЦикла;
			ЗаписатьРезультатЗапросаClickHouseНаСервере(Запрос, Параметры, НоваяДатаОтчета);
			//
			НоваяДатаОтчета = ДатаДнейВперед(Параметры.ДатаНачала, Счетчик);
			//НоваяДатаОтчета = НачалоДня(НоваяДатаОтчета) + 60 * 60 * 24;
		КонецЦикла;
	Иначе
		ЗаписатьРезультатЗапросаClickHouseНаСервере(Запрос, Параметры, Параметры.ДатаНачала);
	КонецЕсли;	 
	
КонецПроцедуры
//<<%%>> ilya@kimkarus.ru @kimkarus kimkarus.ru # Ilya Kosarev 10-07-2023 9:30 end

