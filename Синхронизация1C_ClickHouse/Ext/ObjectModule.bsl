Процедура ЗаписатьРезультатЗапросаClickHouseНаСервере(Запрос, Параметры, ПериодДата)
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	//
	ВыборкаРезультата = РезультатЗапроса.Выгрузить(ОбходРезультатаЗапроса.Прямой);
	Для каждого СтрокаР из ВыборкаРезультата Цикл
		ВставитьЗаписьВClickHouse(СтрокаР, Параметры, ПериодДата);	
	КонецЦикла;
КонецПроцедуры
