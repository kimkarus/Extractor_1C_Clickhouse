		ДополнитеьныеПараметры.Вставить("КоличествоДнейНазад", ПолучитьПараметрМакетаПоИмени("КоличествоДнейНазад", ПараметрыМакета));
	КонецЕсли;
	
	ДополнитеьныеПараметры.Вставить("КоличествоВПортиции", ПолучитьПараметрМакетаПоИмени("КоличествоВПортиции", ПараметрыМакета));
